do_install() {
    install -d ${D}${bindir}
    install -m 0755 ${B}/target/aarch64-unknown-linux-gnu/release/m13-node ${D}${bindir}/m13-node
}

# 4. SYSTEMD SERVICE
SYSTEMD_SERVICE_${PN} = "m13-node.service"
