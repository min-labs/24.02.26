# 3. INSTALLATION
do_install() {
    install -d ${D}${bindir}
    install -m 0755 ${B}/target/aarch64-unknown-linux-gnu/release/m13-hub ${D}${bindir}/m13-hub
}

# 4. SYSTEMD SERVICE
SYSTEMD_SERVICE_${PN} = "m13-hub.service"
